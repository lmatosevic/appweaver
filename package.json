{
  "name": "appweaver",
  "version": "1.0.8",
  "description": "Appweaver - the backend framework for AI-first development",
  "author": "Luka Matosevic",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/lmatosevic/appweaver.git"
  },
  "maintainers": [
    {
      "name": "Luka Matosevic",
      "email": "lukamatosevic5@gmail.com",
      "web": "https://lukamatosevic.com"
    }
  ],
  "engines": {
    "node": ">= 20"
  },
  "scripts": {
    "clean:packages": "rimraf --glob \"packages/**/dist\"",
    "clean:modules": "rimraf node_modules/@appweaver",
    "prebuild": "npm run clean:packages",
    "build": "tsc -b -v packages",
    "postbuild": "npm run clean:modules && node tools/copy-packages.js",
    "test": "jest --forceExit --detectOpenHandles --coverage",
    "format": "prettier --write \"packages/**/*.ts\" \"sample/**/*.ts\"",
    "lint": "eslint \"{packages,sample}/**/*.ts\"",
    "lint:fix": "npm run lint -- --fix",
    "prerelease": "npm run build -- --sourceMap false",
    "release": "semantic-release --no-ci",
    "postrelease": "git push --follow-tags"
  },
  "dependencies": {
    "@fastify/auth": "5.0.4",
    "@fastify/basic-auth": "6.2.0",
    "@fastify/cors": "11.2.0",
    "@fastify/helmet": "13.0.2",
    "@fastify/jwt": "10.1.0",
    "@fastify/multipart": "10.0.0",
    "@fastify/oauth2": "8.2.0",
    "@fastify/rate-limit": "11.0.0",
    "@fastify/request-context": "7.0.0",
    "@fastify/static": "9.1.3",
    "@fastify/swagger": "9.7.0",
    "@fastify/swagger-ui": "6.0.0",
    "@fastify/type-provider-typebox": "6.1.0",
    "@prisma/adapter-better-sqlite3": "7.8.0",
    "@prisma/client": "7.8.0",
    "@sinclair/typebox": "0.34.49",
    "bcrypt": "6.0.0",
    "bullmq": "5.79.1",
    "commander": "15.0.0",
    "cron": "4.4.0",
    "csv-stringify": "6.8.0",
    "date-fns": "4.4.0",
    "dotenv": "17.4.2",
    "fastify": "5.8.5",
    "fastify-plugin": "6.0.0",
    "flatted": "3.4.2",
    "generate-api-key": "1.0.2",
    "glob": "13.0.6",
    "ioredis": "5.11.1",
    "js-yaml": "5.0.0",
    "nodemailer": "9.0.1",
    "openapi-fetch": "0.17.0",
    "openapi-typescript": "7.13.0",
    "openapi-typescript-helpers": "0.1.0",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "pluralize": "8.0.0",
    "prisma": "7.8.0",
    "rotating-file-stream": "3.2.9",
    "rxjs": "7.8.2",
    "tree-kill": "1.2.2"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/exec": "7.1.0",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "11.0.6",
    "@semantic-release/npm": "12.0.2",
    "@sinclair/typebox-codegen": "0.11.1",
    "@swc/core": "1.15.41",
    "@swc/jest": "0.2.39",
    "@types/bcrypt": "6.0.0",
    "@types/bun": "1.3.14",
    "@types/jest": "30.0.0",
    "@types/js-yaml": "4.0.9",
    "@types/node": "26.0.0",
    "@types/nodemailer": "8.0.1",
    "@types/pluralize": "0.0.33",
    "@typescript-eslint/eslint-plugin": "8.61.1",
    "@typescript-eslint/parser": "8.61.1",
    "conventional-changelog-conventionalcommits": "9.3.1",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jest": "29.15.2",
    "eslint-plugin-prettier": "5.5.6",
    "globals": "17.6.0",
    "jest": "30.4.2",
    "jest-junit": "17.0.0",
    "prettier": "3.8.4",
    "rimraf": "6.1.3",
    "semantic-release": "24.2.9",
    "ts-node": "10.9.2",
    "tsc-alias": "1.8.17",
    "tsc-watch": "7.2.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.61.1"
  }
}
