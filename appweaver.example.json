{
  "$schema": "./node_modules/@appweaver/common/config/schema.json",
  "config": {
    "app": {
      "name": "Appweaver",
      "description": "Appweaver - simple, fast, and reliable web application builder tool",
      "hostname": "http://localhost:6000",
      "scanPath": "./dist/src",
      "autoloadModules": []
    },
    "server": {
      "port": 6000,
      "host": "0.0.0.0",
      "apiPrefix": "/api",
      "bodyLimitBytes": 104857600,
      "staticEnabled": true,
      "staticDirPath": "./public",
      "staticRoutePrefix": "/public",
      "staticMaxAge": "30d",
      "staticAllowedHost": null,
      "requestLoggingEnabled": false
    },
    "log": {
      "level": "info",
      "path": "./logs",
      "rotate": true,
      "rotateSize": "100M",
      "rotateMaxSize": "5G",
      "rotateMaxFiles": 1000,
      "rotateInterval": "1d",
      "rotateCompress": true,
      "pretty": false
    },
    "rateLimit": {
      "enabled": true,
      "max": 1000,
      "window": 60000,
      "store": "redis"
    },
    "swagger": {
      "enabled": true,
      "path": "/swagger",
      "hideUntagged": false
    },
    "healthCheck": {
      "enabled": true,
      "routePrefix": "/health"
    },
    "cors": {
      "origin": "*",
      "methods": "*",
      "allowedHeaders": "*",
      "exposedHeaders": "*",
      "maxAge": 86400,
      "credentials": true
    },
    "resource": {
      "modelPattern": "./src/resources/*/model.ts",
      "servicePattern": "./src/resources/*/service.ts",
      "policyPattern": "./src/resources/*/policy.ts",
      "routePattern": "./src/resources/*/route.ts",
      "generatedTypesPath": "./src/types/generated.ts"
    },
    "export": {
      "csv": {
        "delimiter": ";",
        "joinDelimiter": ",",
        "addHeaders": true,
        "addSepRow": false
      },
      "batchSize": 1000
    },
    "security": {
      "routePrefix": "/auth",
      "jwt": {
        "secret": "GdvCFezoPIZdOAN3IQZR3JhaAZH6S6AJ",
        "expiresIn": 2592000,
        "refreshExpiresIn": 5184000
      }
    },
    "database": {
      "type": "postgresql",
      "url": "postgresql://appweaver:appweaver@localhost:5432/appweaver-sample?schema=public",
      "schemaPath": "./database/schema.prisma",
      "migrationsDirPath": "./database/migrations",
      "clientOutputPath": "./database/client",
      "transactionMaxWait": 2000,
      "transactionTimeout": 5000,
      "provider": "@appweaver/core/database/prisma-database"
    },
    "storage": {
      "path": "./storage",
      "namePattern": "{name}-{hash}.{extension}",
      "cacheDuration": 86400,
      "provider": "@appweaver/core/storage/filesystem-storage"
    },
    "redis": {
      "url": "redis://localhost:6379/0",
      "provider": "@appweaver/core/memory/redis"
    },
    "memory": {
      "maxSizeBytes": 104857600,
      "provider": "@appweaver/core/memory/memory"
    },
    "cache": {
      "enabled": true,
      "cleanStart": false,
      "keyPrefix": "cache:",
      "defaultTtl": 5000,
      "evictionGracePeriod": 10000,
      "evictionStrategy": "LRU",
      "evictionDeferred": false,
      "invalidationStrategy": "expire-related",
      "invalidationDeferred": false,
      "provider": "@appweaver/core/cache/redis-cache"
    },
    "queue": {
      "keepCompletedCount": 0,
      "keepCompletedSeconds": null,
      "keepFailedCount": 50,
      "keepFailedSeconds": null,
      "retryAttempts": 3,
      "retryBackoff": 3000,
      "retryBackoffType": "fixed",
      "provider": "@appweaver/core/queue/bull-queue"
    },
    "scheduler": {
      "autoStartJob": true,
      "provider": "@appweaver/core/scheduler/cron-scheduler"
    },
    "events": {
      "maxListeners": 10,
      "provider": "@appweaver/core/events/node-events"
    },
    "mail": {
      "smtp": {
        "host": "mail.appweaver.com",
        "port": 587,
        "secure": false,
        "user": "no-reply@appweaver.com",
        "password": ""
      },
      "senderName": "John Doe",
      "senderAddress": "no-reply@appweaver.com",
      "provider": "@appweaver/core/mailer/smtp-mailer"
    },
    "system": {
      "adminInitialEmail": "admin@appweaver.com",
      "adminInitialPassword": "Password1!"
    }
  }
}
