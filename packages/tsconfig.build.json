{
  "compilerOptions": {
    "composite": true,
    "module": "CommonJS",
    "target": "ES2024",
    "strict": true,
    "sourceMap": true,
    "declaration": true,
    "stripInternal": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "incremental": true,
    "removeComments": false,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "types": ["node"]
  }
}
