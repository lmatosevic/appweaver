{
  "extends": "../tsconfig.build.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",
    "paths": {
      "@appweaver/common": ["../common"],
      "@appweaver/common/*": ["../common/*"]
    }
  },
  "exclude": [
    "node_modules",
    "dist",
    "prisma/migrations",
    "prisma/schema.prisma",
    "prisma.config.ts",
    "test/**/*",
    "*.(spec|test).ts"
  ],
  "references": [
    {
      "path": "../common/tsconfig.build.json"
    }
  ]
}
