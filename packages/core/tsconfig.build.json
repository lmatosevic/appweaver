{
  "extends": "../tsconfig.build.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",
    "paths": {
      "@prisma/client": ["./node_modules/.prisma/client"],
      "@prisma/client/*": ["./node_modules/.prisma/client/*"],
      "@appweaver/common": ["../common"],
      "@appweaver/common/*": ["../common/*"]
    }
  },
  "exclude": [
    "node_modules",
    "dist",
    "prisma",
    "prisma.config.ts",
    "test/**/*",
    "*.(spec|test).ts"
  ],
  "references": [
    {
      "path": "../common/tsconfig.build.json"
    }
  ]
}
