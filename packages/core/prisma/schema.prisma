// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

model Identity {
  id           Int       @id @default(autoincrement())
  username     String    @unique
  passwordHash String?
  enabled      Boolean   @default(true)
  logoutAt     DateTime?

  /// Related columns
  roles Role[] @relation("IdentityRoles")

  /// Audit columns
  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())
  createdBy   Identity? @relation("IdentityCreatedByIdentity", fields: [createdById], references: [id])
  createdById Int?

  /// Ownership relations connected with createdById column
  createdIdentities Identity[] @relation("IdentityCreatedByIdentity")
  createdFiles      File[]     @relation("FileCreatedByIdentity")
}

model Role {
  id   Int    @id @default(autoincrement())
  name String @unique

  /// Related columns
  identities Identity[] @relation("IdentityRoles")

  /// Audit columns
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model File {
  id            Int     @id @default(autoincrement())
  name          String  @unique
  originalName  String
  mimeType      String
  sizeBytes     Int
  title         String?
  description   String?
  resourceField String?
  resourceName  String?
  resourceId    Int?

  /// Audit columns
  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())
  createdBy   Identity? @relation("FileCreatedByIdentity", fields: [createdById], references: [id])
  createdById Int?

  @@index([resourceField, resourceName, resourceId])
}
