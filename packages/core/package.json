{
  "name": "@appweaver/core",
  "version": "0.1.0",
  "description": "Appweaver - simple, fast, and reliable web application builder tool (@core)",
  "author": "Luka Matosevic",
  "license": "UNLICENSED",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/app-weaver/appweaver.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">= 20"
  },
  "scripts": {
    "weaver": "node ./../../node_modules/@appweaver/cli/dist/weaver.js",
    "generate-types": "npm run weaver -- generate --types --modelPattern ./**/model.ts --typesPath ./types/generated.ts",
    "generate-schema": "npm run weaver -- generate --schema --modelPattern ./**/model.ts --schemaPath ./prisma/schema.prisma",
    "db:remove": "rimraf dev.db && rimraf prisma/migrations --glob \"*_init\"",
    "db:recreate": "npm run db:remove && prisma migrate dev --name init && npm run db:generate",
    "db:migrate": "prisma migrate deploy",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@fastify/cors": "11.2.0",
    "@fastify/helmet": "13.0.2",
    "@fastify/jwt": "10.0.0",
    "@fastify/multipart": "9.4.0",
    "@fastify/rate-limit": "10.3.0",
    "@fastify/request-context": "6.2.1",
    "@fastify/static": "9.0.0",
    "@fastify/swagger": "9.6.1",
    "@fastify/swagger-ui": "5.2.4",
    "@fastify/type-provider-typebox": "6.1.0",
    "@prisma/adapter-better-sqlite3": "7.3.0",
    "@prisma/client": "7.3.0",
    "@sinclair/typebox": "0.34.47",
    "cron": "4.4.0",
    "csv-stringify": "6.6.0",
    "date-fns": "4.1.0",
    "fastify": "5.7.3",
    "glob": "13.0.1",
    "prisma": "7.3.0"
  },
  "devDependencies": {
    "@appweaver/common": "^0.1.0"
  },
  "peerDependencies": {
    "@appweaver/common": "^0.1.0"
  },
  "peerDependenciesMeta": {
    "@appweaver/common": {
      "optional": false
    }
  }
}
