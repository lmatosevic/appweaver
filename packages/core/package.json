{
  "name": "@appweaver/core",
  "version": "1.0.1",
  "description": "Appweaver - simple, fast, and reliable web application builder tool (@core)",
  "author": "Luka Matosevic",
  "license": "UNLICENSED",
  "main": "./index.js",
  "types": "./index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/app-weaver/appweaver.git",
    "directory": "packages/core"
  },
  "maintainers": [
    {
      "name": "Luka Matosevic",
      "email": "lukamatosevic5@gmail.com",
      "web": "https://lukamatosevic.com"
    }
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://gitlab.com/api/v4/projects/77748589/packages/npm/"
  },
  "engines": {
    "node": ">= 20"
  },
  "scripts": {
    "generate": "weaver generate --modelPattern ./**/model.ts --typesPath ./types/generated.ts --schemaPath ./prisma/schema.prisma --clientPath ./prisma/client",
    "db:recreate": "rimraf dev.db && rimraf prisma/migrations --glob \"*_init\" && weaver migration new init"
  },
  "dependencies": {
    "@fastify/auth": "5.0.4",
    "@fastify/basic-auth": "6.2.0",
    "@fastify/cors": "11.2.0",
    "@fastify/helmet": "13.0.2",
    "@fastify/jwt": "10.0.0",
    "@fastify/multipart": "9.4.0",
    "@fastify/oauth2": "8.2.0",
    "@fastify/rate-limit": "10.3.0",
    "@fastify/request-context": "6.2.1",
    "@fastify/static": "9.1.3",
    "@fastify/swagger": "9.6.1",
    "@fastify/swagger-ui": "5.2.4",
    "@fastify/type-provider-typebox": "6.1.0",
    "@sinclair/typebox": "0.34.47",
    "bcrypt": "6.0.0",
    "csv-stringify": "6.6.0",
    "date-fns": "4.1.0",
    "fastify": "5.8.5",
    "flatted": "3.4.2"
  },
  "devDependencies": {
    "@appweaver/common": "^1.0.0",
    "@prisma/adapter-better-sqlite3": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "bullmq": "^5.70.0",
    "cron": "^4.4.0",
    "ioredis": "^5.9.0",
    "nodemailer": "^8.0.0",
    "prisma": "^7.3.0",
    "rimraf": "6.1.2"
  },
  "peerDependencies": {
    "@appweaver/common": "^1.0.0",
    "@prisma/client": "^7.3.0"
  }
}
