{
  "name": "@appweaver/core",
  "version": "1.0.10",
  "description": "Appweaver - the backend framework for AI-first development (@core)",
  "author": "Luka Matosevic",
  "license": "MIT",
  "main": "./index.js",
  "types": "./index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/lmatosevic/appweaver.git",
    "directory": "packages/core"
  },
  "maintainers": [
    {
      "name": "Luka Matosevic",
      "email": "lukamatosevic5@gmail.com",
      "web": "https://lukamatosevic.com"
    }
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">= 20"
  },
  "scripts": {
    "generate": "weaver generate --modelPattern ./**/model.ts --typesPath ./types/generated.ts --schemaPath ./prisma/schema.prisma --clientPath ./prisma/client",
    "db:recreate": "rimraf dev.db && rimraf prisma/migrations --glob \"*_init\" && weaver migration new init"
  },
  "dependencies": {
    "@fastify/auth": "5.0.4",
    "@fastify/basic-auth": "6.2.0",
    "@fastify/cors": "11.2.0",
    "@fastify/helmet": "13.0.2",
    "@fastify/jwt": "10.1.0",
    "@fastify/multipart": "10.0.0",
    "@fastify/oauth2": "8.2.0",
    "@fastify/rate-limit": "11.0.0",
    "@fastify/request-context": "7.0.0",
    "@fastify/static": "9.1.3",
    "@fastify/swagger": "9.7.0",
    "@fastify/swagger-ui": "6.0.0",
    "@fastify/type-provider-typebox": "6.1.0",
    "@sinclair/typebox": "0.34.49",
    "bcrypt": "6.0.0",
    "csv-stringify": "6.8.0",
    "date-fns": "4.4.0",
    "fastify": "5.8.5",
    "fastify-plugin": "6.0.0",
    "flatted": "3.4.2"
  },
  "devDependencies": {
    "@appweaver/common": "^1.0.0",
    "@prisma/adapter-better-sqlite3": "7.8.0",
    "@prisma/client": "7.8.0",
    "bullmq": "5.79.1",
    "cron": "4.4.0",
    "ioredis": "5.11.1",
    "nodemailer": "9.0.1",
    "prisma": "7.8.0",
    "rimraf": "6.1.3"
  },
  "peerDependencies": {
    "@appweaver/common": "^1.0.0",
    "@prisma/client": "^7.3.0"
  }
}
