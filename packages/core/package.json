{
  "name": "@appweaver/core",
  "version": "1.5.2",
  "description": "Appweaver - simple, fast, and reliable web application builder tool (@core)",
  "author": "Luka Matosevic",
  "license": "UNLICENSED",
  "main": "./index.js",
  "types": "./index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/app-weaver/appweaver.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://gitlab.com/api/v4/projects/77748589/packages/npm/"
  },
  "engines": {
    "node": ">= 20"
  },
  "scripts": {
    "weaver": "node ./../../node_modules/@appweaver/cli/weaver.js",
    "generate": "npm run weaver -- generate --modelPattern ./**/model.ts --typesPath ./types/generated.ts --schemaPath ./prisma/schema.prisma --clientPath ./prisma/client",
    "db:remove": "rimraf dev.db && rimraf prisma/migrations --glob \"*_init\"",
    "db:recreate": "npm run db:remove && prisma migrate dev --name init && npm run db:generate",
    "db:migrate": "prisma migrate deploy",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@fastify/auth": "5.0.4",
    "@fastify/basic-auth": "6.2.0",
    "@fastify/cors": "11.2.0",
    "@fastify/helmet": "13.0.2",
    "@fastify/jwt": "10.0.0",
    "@fastify/multipart": "9.4.0",
    "@fastify/oauth2": "8.2.0",
    "@fastify/rate-limit": "10.3.0",
    "@fastify/request-context": "6.2.1",
    "@fastify/static": "9.0.0",
    "@fastify/swagger": "9.6.1",
    "@fastify/swagger-ui": "5.2.4",
    "@fastify/type-provider-typebox": "6.1.0",
    "@prisma/client": "7.5.0",
    "@sinclair/typebox": "0.34.47",
    "bcrypt": "6.0.0",
    "csv-stringify": "6.6.0",
    "date-fns": "4.1.0",
    "fastify": "5.8.1",
    "flatted": "3.4.2",
    "glob": "13.0.1"
  },
  "devDependencies": {
    "@appweaver/common": "^1.0.0",
    "@prisma/adapter-better-sqlite3": "^7.3.0",
    "bullmq": "^5.70.0",
    "cron": "^4.4.0",
    "ioredis": "^5.9.0",
    "nodemailer": "^8.0.0",
    "prisma": "^7.3.0"
  },
  "peerDependencies": {
    "@appweaver/common": "^1.0.0",
    "@prisma/adapter-better-sqlite3": "^7.3.0",
    "@prisma/adapter-mariadb": "^7.3.0",
    "@prisma/adapter-mssql": "^7.3.0",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "bullmq": "^5.70.0",
    "cron": "^4.4.0",
    "ioredis": "^5.9.0",
    "nodemailer": "^8.0.0",
    "prisma": "^7.3.0"
  },
  "peerDependenciesMeta": {
    "@prisma/adapter-better-sqlite3": {
      "optional": true
    },
    "@prisma/adapter-mariadb": {
      "optional": true
    },
    "@prisma/adapter-mssql": {
      "optional": true
    },
    "@prisma/adapter-pg": {
      "optional": true
    },
    "bullmq": {
      "optional": true
    },
    "cron": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "nodemailer": {
      "optional": true
    }
  }
}
