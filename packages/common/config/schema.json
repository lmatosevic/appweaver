{
  "$schema": "http://json-schema.org/draft-07/schema",
  "$id": "appweaver://config/schema.json",
  "title": "Appweaver Workspace Configuration",
  "type": "object",
  "additionalProperties": false,
  "required": [],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "config": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "app": {
          "type": "object",
          "properties": {
            "env": {
              "anyOf": [
                {
                  "type": "string",
                  "enum": ["test", "local", "dev", "staging", "qa", "prod"],
                  "default": "prod"
                },
                { "type": "string" }
              ]
            },
            "name": {
              "type": "string",
              "default": "Appweaver"
            },
            "version": {
              "type": "string",
              "default": "unknown"
            },
            "description": {
              "type": ["string", "null"]
            },
            "hostname": {
              "type": "string",
              "default": ""
            },
            "runtime": {
              "type": "string",
              "enum": ["node", "bun"],
              "default": "node"
            },
            "buildPath": {
              "type": "string",
              "default": "./dist"
            },
            "sourcePath": {
              "type": "string",
              "default": "./src"
            },
            "scanFilesPattern": {
              "type": "string",
              "default": "<srcPath>/*/index.ts"
            },
            "mainFilePath": {
              "type": "string",
              "default": "<srcPath>/main.ts"
            },
            "autoloadModules": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            }
          }
        },
        "log": {
          "type": "object",
          "properties": {
            "level": {
              "type": "string",
              "enum": [
                "silent",
                "trace",
                "debug",
                "info",
                "warn",
                "error",
                "fatal"
              ],
              "default": "info"
            },
            "path": {
              "type": ["string", "null"]
            },
            "rotate": {
              "type": "boolean",
              "default": true
            },
            "rotateSize": {
              "type": "string",
              "default": "100M"
            },
            "rotateMaxSize": {
              "type": "string",
              "default": "5G"
            },
            "rotateMaxFiles": {
              "type": "integer",
              "default": 1000
            },
            "rotateInterval": {
              "type": "string",
              "default": "1d"
            },
            "rotateCompress": {
              "type": "boolean",
              "default": true
            },
            "pretty": {
              "type": "boolean",
              "default": false
            }
          }
        },
        "server": {
          "type": "object",
          "properties": {
            "port": {
              "type": "integer",
              "default": 5000
            },
            "host": {
              "type": "string",
              "default": "0.0.0.0"
            },
            "apiPrefix": {
              "type": "string",
              "default": "/api"
            },
            "staticEnabled": {
              "type": "boolean",
              "default": true
            },
            "bodyLimitBytes": {
              "type": "integer",
              "default": 104857600
            },
            "staticDirPath": {
              "type": "string",
              "default": "./public"
            },
            "staticRoutePrefix": {
              "type": "string",
              "default": "/public"
            },
            "staticMaxAge": {
              "type": "string",
              "default": "30d"
            },
            "staticAllowedHost": {
              "type": ["string", "null"]
            },
            "trustProxy": {
              "type": "boolean",
              "default": true
            },
            "requestLoggingEnabled": {
              "type": "boolean",
              "default": false
            }
          }
        },
        "rateLimit": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true
            },
            "max": {
              "type": "integer",
              "default": 1000
            },
            "window": {
              "type": "integer",
              "default": 60000
            },
            "allowList": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "store": {
              "type": "string",
              "enum": ["redis", "in-memory"],
              "default": "redis"
            }
          }
        },
        "swagger": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true
            },
            "path": {
              "type": "string",
              "default": "/swagger"
            },
            "hideUntagged": {
              "type": "boolean",
              "default": false
            }
          }
        },
        "healthCheck": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true
            },
            "auth": {
              "type": "boolean",
              "default": true
            },
            "routePrefix": {
              "type": "string",
              "default": "/health"
            },
            "pickInstances": {
              "oneOf": [
                { "type": "null" },
                { "type": "string" },
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              ],
              "default": null
            },
            "omitInstances": {
              "oneOf": [
                { "type": "null" },
                { "type": "string" },
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              ],
              "default": null
            }
          }
        },
        "cors": {
          "type": "object",
          "properties": {
            "origin": {
              "type": "string",
              "default": "*"
            },
            "methods": {
              "oneOf": [
                { "type": "string" },
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              ],
              "default": ["*"]
            },
            "allowedHeaders": {
              "oneOf": [
                { "type": "string" },
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              ],
              "default": ["*"]
            },
            "exposedHeaders": {
              "oneOf": [
                { "type": "string" },
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              ],
              "default": ["*"]
            },
            "maxAge": {
              "type": "integer",
              "default": 86400
            },
            "credentials": {
              "type": "boolean",
              "default": true
            }
          }
        },
        "resource": {
          "type": "object",
          "properties": {
            "modelPattern": {
              "type": "string",
              "default": "<srcPath>/resources/*/*model.ts"
            },
            "servicePattern": {
              "type": "string",
              "default": "<srcPath>/resources/*/*service.ts"
            },
            "policyPattern": {
              "type": "string",
              "default": "<srcPath>/resources/*/*policy.ts"
            },
            "routesPattern": {
              "type": "string",
              "default": "<srcPath>/resources/*/*routes.ts"
            },
            "generatedTypesPath": {
              "type": "string",
              "default": "<srcPath>/types/generated.ts"
            }
          }
        },
        "export": {
          "type": "object",
          "properties": {
            "batchSize": {
              "type": "integer",
              "default": 1000
            },
            "csv": {
              "type": "object",
              "properties": {
                "delimiter": {
                  "type": "string",
                  "default": ";"
                },
                "joinDelimiter": {
                  "type": "string",
                  "default": ","
                },
                "addHeaders": {
                  "type": "boolean",
                  "default": true
                },
                "addSepRow": {
                  "type": "boolean",
                  "default": false
                }
              }
            }
          }
        },
        "security": {
          "type": "object",
          "properties": {
            "routePrefix": {
              "type": "string",
              "default": "/auth"
            },
            "cacheTtl": {
              "type": "integer",
              "default": 300000
            },
            "authOttTtl": {
              "type": "integer",
              "default": 120000
            },
            "allowedRedirectHosts": {
              "oneOf": [
                { "type": "string" },
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              ],
              "default": ["*"]
            },
            "store": {
              "provider": {
                "type": "string",
                "default": "@appweaver/core/security/store/redis-security-store"
              },
              "keepDatabaseTable": {
                "type": "boolean",
                "default": false
              }
            },
            "password": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "default": true
                },
                "minLength": {
                  "type": "integer",
                  "default": 8
                },
                "maxLength": {
                  "type": "integer",
                  "default": 100
                },
                "uppercase": {
                  "type": "boolean",
                  "default": true
                },
                "lowercase": {
                  "type": "boolean",
                  "default": true
                },
                "numeric": {
                  "type": "boolean",
                  "default": true
                },
                "special": {
                  "type": "boolean",
                  "default": true
                }
              }
            },
            "account": {
              "type": "object",
              "properties": {
                "routePrefix": {
                  "type": "string",
                  "default": "/auth/account"
                },
                "verifyEmail": {
                  "type": "object",
                  "properties": {
                    "enabled": {
                      "type": "boolean",
                      "default": true
                    },
                    "ottTtl": {
                      "type": "integer",
                      "default": 7200000
                    }
                  }
                },
                "resetPassword": {
                  "type": "object",
                  "properties": {
                    "enabled": {
                      "type": "boolean",
                      "default": true
                    },
                    "ottTtl": {
                      "type": "integer",
                      "default": 1800000
                    }
                  }
                },
                "2fa": {
                  "type": "object",
                  "properties": {
                    "enabled": {
                      "type": "boolean",
                      "default": true
                    },
                    "forced": {
                      "type": "boolean",
                      "default": false
                    },
                    "ottTtl": {
                      "type": "integer",
                      "default": 300000
                    }
                  }
                }
              }
            },
            "recaptcha": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "default": false
                },
                "secret": {
                  "type": ["string", "null"]
                },
                "headerName": {
                  "type": "string",
                  "default": "x-recaptcha-token"
                },
                "minScore": {
                  "type": "number",
                  "default": 0.4
                },
                "verifyUrl": {
                  "type": "string",
                  "default": "https://www.google.com/recaptcha/api/siteverify"
                }
              }
            },
            "basic": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "default": false
                },
                "realm": {
                  "type": ["string", "null"]
                },
                "proxyMode": {
                  "type": "boolean",
                  "default": false
                }
              }
            },
            "apiKey": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "default": false
                },
                "keepDatabaseTable": {
                  "type": "boolean",
                  "default": false
                },
                "headerName": {
                  "type": "string",
                  "default": "x-api-key"
                },
                "maxDuration": {
                  "type": ["integer", "null"]
                },
                "delimiter": {
                  "type": "string",
                  "default": "AK"
                }
              }
            },
            "jwt": {
              "type": "object",
              "properties": {
                "secret": {
                  "type": "string"
                },
                "publicKeyPath": {
                  "type": "string",
                  "default": "./storage/keys/public.key"
                },
                "privateKeyPath": {
                  "type": "string",
                  "default": "./storage/keys/private.key"
                },
                "autoGenerateKeys": {
                  "type": "boolean",
                  "default": true
                },
                "expiresIn": {
                  "type": "integer",
                  "default": 2592000
                },
                "refreshExpiresIn": {
                  "type": "integer",
                  "default": 5184000
                }
              }
            },
            "oauth2": {
              "type": "object",
              "properties": {
                "stateTtl": {
                  "type": "integer",
                  "default": 600000
                },
                "google": {
                  "type": "object",
                  "properties": {
                    "enabled": {
                      "type": "boolean",
                      "default": false
                    },
                    "clientId": {
                      "type": "string"
                    },
                    "clientSecret": {
                      "type": "string"
                    },
                    "userInfoUrl": {
                      "type": "string",
                      "default": "https://www.googleapis.com/oauth2/v2/userinfo"
                    }
                  }
                },
                "facebook": {
                  "type": "object",
                  "properties": {
                    "enabled": {
                      "type": "boolean",
                      "default": false
                    },
                    "clientId": {
                      "type": "string"
                    },
                    "clientSecret": {
                      "type": "string"
                    },
                    "userInfoUrl": {
                      "type": "string",
                      "default": "https://graph.facebook.com/me"
                    }
                  }
                },
                "custom": {
                  "type": "object",
                  "properties": {
                    "enabled": {
                      "type": "boolean",
                      "default": false
                    },
                    "clientId": {
                      "type": "string"
                    },
                    "clientSecret": {
                      "type": "string"
                    },
                    "issuer": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "database": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["sqlite", "postgresql", "mysql", "sqlserver"]
            },
            "url": {
              "type": "string",
              "default": ""
            },
            "schemaPath": {
              "type": "string",
              "default": "./database/schema.prisma"
            },
            "migrationsDirPath": {
              "type": "string",
              "default": "./database/migrations"
            },
            "seedersDirPath": {
              "type": "string",
              "default": "./database/seeders"
            },
            "clientOutputDirPath": {
              "type": "string",
              "default": "./database/client"
            },
            "transactionMaxWait": {
              "type": "integer",
              "default": 2000
            },
            "transactionTimeout": {
              "type": "integer",
              "default": 5000
            },
            "logEvents": {
              "oneOf": [
                {
                  "type": "string",
                  "enum": ["query", "info", "warn", "error"]
                },
                {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": ["query", "info", "warn", "error"]
                  }
                }
              ],
              "default": []
            },
            "provider": {
              "type": "string",
              "default": "@appweaver/core/database/prisma-database"
            }
          }
        },
        "storage": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string",
              "default": "./storage"
            },
            "namePattern": {
              "type": "string",
              "default": "{name}-{hash}.{extension}"
            },
            "cacheTtl": {
              "type": "integer",
              "default": 86400000
            },
            "provider": {
              "type": "string",
              "default": "@appweaver/core/storage/filesystem-storage"
            }
          }
        },
        "redis": {
          "type": "object",
          "properties": {
            "url": {
              "type": "string",
              "default": "redis://localhost:6379/0"
            },
            "provider": {
              "type": "string",
              "default": "@appweaver/core/memory/redis"
            }
          }
        },
        "memory": {
          "type": "object",
          "properties": {
            "maxSizeBytes": {
              "type": ["integer", "null"]
            },
            "provider": {
              "type": "string",
              "default": "@appweaver/core/memory/in-memory"
            }
          }
        },
        "cache": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true
            },
            "cleanStart": {
              "type": "boolean",
              "default": false
            },
            "keyPrefix": {
              "type": "string",
              "default": "cache:"
            },
            "maxItems": {
              "type": "integer",
              "default": 1000
            },
            "maxSizeBytes": {
              "type": ["integer", "null"]
            },
            "defaultTtl": {
              "type": "integer",
              "default": 5000
            },
            "evictionGracePeriod": {
              "type": "integer",
              "default": 1000
            },
            "evictionStrategy": {
              "type": "string",
              "enum": ["LRU", "LFU", "FIFO"],
              "default": "LRU"
            },
            "evictionDeferred": {
              "type": "boolean",
              "default": false
            },
            "invalidationStrategy": {
              "type": "string",
              "enum": ["expire-related", "expire-all", "none"],
              "default": "expire-related"
            },
            "invalidationDeferred": {
              "type": "boolean",
              "default": false
            },
            "provider": {
              "type": "string",
              "default": "@appweaver/core/cache/redis-cache"
            }
          }
        },
        "queue": {
          "type": "object",
          "properties": {
            "keepCompletedCount": {
              "type": "integer",
              "default": 0
            },
            "keepCompletedSeconds": {
              "type": ["integer", "null"]
            },
            "keepFailedCount": {
              "type": "integer",
              "default": 50
            },
            "keepFailedSeconds": {
              "type": ["integer", "null"]
            },
            "retryAttempts": {
              "type": "integer",
              "default": 3
            },
            "retryBackoff": {
              "type": "integer",
              "default": 3000
            },
            "retryBackoffType": {
              "type": "string",
              "enum": ["fixed", "exponential"],
              "default": "fixed"
            },
            "provider": {
              "type": "string",
              "default": "@appweaver/core/queue/bull-queue"
            }
          }
        },
        "scheduler": {
          "type": "object",
          "properties": {
            "autoStartJob": {
              "type": "boolean",
              "default": true
            },
            "provider": {
              "type": "string",
              "default": "@appweaver/core/scheduler/cron-scheduler"
            }
          }
        },
        "events": {
          "type": "object",
          "properties": {
            "maxListeners": {
              "type": "integer",
              "default": 20
            },
            "provider": {
              "type": "string",
              "default": "@appweaver/core/events/node-events"
            }
          }
        },
        "mailer": {
          "type": "object",
          "properties": {
            "senderName": {
              "type": ["string", "null"]
            },
            "senderAddress": {
              "type": ["string", "null"]
            },
            "provider": {
              "type": "string",
              "default": "@appweaver/core/mailer/smtp-mailer"
            },
            "smtp": {
              "type": "object",
              "properties": {
                "host": {
                  "type": "string",
                  "default": "127.0.0.1"
                },
                "port": {
                  "type": "integer",
                  "default": 587
                },
                "secure": {
                  "type": "boolean",
                  "default": false
                },
                "user": {
                  "type": ["string", "null"]
                },
                "password": {
                  "type": ["string", "null"]
                }
              }
            }
          }
        },
        "system": {
          "type": "object",
          "properties": {
            "adminInitialEmail": {
              "type": "string",
              "default": "admin@appweaver.co"
            },
            "adminInitialPassword": {
              "type": ["string", "null"]
            }
          }
        }
      }
    }
  }
}
