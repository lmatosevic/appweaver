{
  "$schema": "http://json-schema.org/draft-07/schema",
  "$id": "appweaver://config/schema.json",
  "title": "Appweaver Workspace Configuration",
  "type": "object",
  "additionalProperties": false,
  "required": [],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "config": {
      "type": "object",
      "properties": {
        "app": {
          "type": "object",
          "properties": {
            "env": {
              "anyOf": [
                {
                  "type": "string",
                  "enum": ["test", "local", "dev", "staging", "qa", "prod"],
                  "default": "prod"
                },
                { "type": "string" }
              ]
            },
            "name": {
              "type": "string",
              "default": "Appweaver"
            },
            "description": {
              "type": ["string", "null"]
            },
            "hostname": {
              "type": "string",
              "default": "http://localhost:6000"
            },
            "version": {
              "type": "string",
              "default": "unknown"
            },
            "scanPath": {
              "type": ["string", "null"]
            },
            "autoloadModules": {
              "oneOf": [
                { "type": "string" },
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              ],
              "default": []
            }
          }
        },
        "log": {
          "type": "object",
          "properties": {
            "level": {
              "type": "string",
              "enum": [
                "silent",
                "trace",
                "debug",
                "info",
                "warn",
                "error",
                "fatal"
              ],
              "default": "info"
            },
            "path": {
              "type": ["string", "null"]
            },
            "rotate": {
              "type": "boolean",
              "default": true
            },
            "rotateSize": {
              "type": "string",
              "default": "100M"
            },
            "rotateMaxSize": {
              "type": "string",
              "default": "5G"
            },
            "rotateMaxFiles": {
              "type": "integer",
              "default": 1000
            },
            "rotateInterval": {
              "type": "string",
              "default": "1d"
            },
            "rotateCompress": {
              "type": "boolean",
              "default": true
            },
            "pretty": {
              "type": "boolean",
              "default": false
            }
          }
        },
        "server": {
          "type": "object",
          "properties": {
            "port": {
              "type": "integer",
              "default": 6000
            },
            "host": {
              "type": "string",
              "default": "0.0.0.0"
            },
            "apiPrefix": {
              "type": "string",
              "default": "/api"
            },
            "staticEnabled": {
              "type": "boolean",
              "default": true
            },
            "bodyLimitBytes": {
              "type": "integer",
              "default": 104857600
            },
            "staticDirPath": {
              "type": "string",
              "default": "./public"
            },
            "staticRoutePrefix": {
              "type": "string",
              "default": "/public"
            },
            "staticMaxAge": {
              "type": "string",
              "default": "30d"
            },
            "staticAllowedHost": {
              "type": ["string", "null"]
            },
            "requestLoggingEnabled": {
              "type": "boolean",
              "default": false
            }
          }
        },
        "rateLimit": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true
            },
            "max": {
              "type": "integer",
              "default": 1000
            },
            "window": {
              "type": "integer",
              "default": 60000
            },
            "store": {
              "type": "string",
              "enum": ["redis", "in-memory"],
              "default": "redis"
            }
          }
        },
        "swagger": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true
            },
            "path": {
              "type": "string",
              "default": "/swagger"
            },
            "hideUntagged": {
              "type": "boolean",
              "default": false
            }
          }
        },
        "healthCheck": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true
            },
            "routePrefix": {
              "type": "string",
              "default": "/health"
            }
          }
        },
        "cors": {
          "type": "object",
          "properties": {
            "origin": {
              "type": "string",
              "default": "*"
            },
            "methods": {
              "oneOf": [
                { "type": "string" },
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              ],
              "default": ["*"]
            },
            "allowedHeaders": {
              "oneOf": [
                { "type": "string" },
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              ],
              "default": ["*"]
            },
            "exposedHeaders": {
              "oneOf": [
                { "type": "string" },
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              ],
              "default": ["*"]
            },
            "maxAge": {
              "type": "integer",
              "default": 86400
            },
            "credentials": {
              "type": "boolean",
              "default": true
            }
          }
        },
        "resource": {
          "type": "object",
          "properties": {
            "modelPattern": {
              "type": "string",
              "default": "./src/resources/*/model.ts"
            },
            "servicePattern": {
              "type": "string",
              "default": "./src/resources/*/service.ts"
            },
            "policyPattern": {
              "type": "string",
              "default": "./src/resources/*/policy.ts"
            },
            "routePattern": {
              "type": "string",
              "default": "./src/resources/*/route.ts"
            },
            "generatedTypesPath": {
              "type": "string",
              "default": "./src/types/generated.ts"
            }
          }
        },
        "export": {
          "type": "object",
          "properties": {
            "batchSize": {
              "type": "integer",
              "default": 1000
            },
            "csv": {
              "type": "object",
              "properties": {
                "delimiter": {
                  "type": "string",
                  "default": ";"
                },
                "joinDelimiter": {
                  "type": "string",
                  "default": ","
                },
                "addHeaders": {
                  "type": "boolean",
                  "default": true
                },
                "addSepRow": {
                  "type": "boolean",
                  "default": false
                }
              }
            }
          }
        },
        "security": {
          "type": "object",
          "properties": {
            "routePrefix": {
              "type": "string",
              "default": "/auth"
            },
            "cacheTtl": {
              "type": "integer",
              "default": 300000
            },
            "jwt": {
              "type": "object",
              "properties": {
                "secret": {
                  "type": "string",
                  "default": "abcdefghijklmnopqrst12345"
                },
                "expiresIn": {
                  "type": "integer",
                  "default": 2592000
                },
                "refreshExpiresIn": {
                  "type": "integer",
                  "default": 5184000
                }
              }
            }
          }
        },
        "database": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["sqlite", "postgresql", "mysql", "sqlserver"]
            },
            "url": {
              "type": "string",
              "default": ""
            },
            "schemaPath": {
              "type": "string",
              "default": "./database/schema.prisma"
            },
            "migrationsDirPath": {
              "type": "string",
              "default": "./database/migrations"
            },
            "clientOutputPath": {
              "type": "string",
              "default": "./database/client"
            },
            "transactionMaxWait": {
              "type": "integer",
              "default": 2000
            },
            "transactionTimeout": {
              "type": "integer",
              "default": 5000
            },
            "provider": {
              "type": "string",
              "default": "@appweaver/core/database/prisma-database"
            }
          }
        },
        "storage": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string",
              "default": "./storage"
            },
            "namePattern": {
              "type": "string",
              "default": "{name}-{hash}.{extension}"
            },
            "cacheTtl": {
              "type": "integer",
              "default": 86400000
            },
            "provider": {
              "type": "string",
              "default": "@appweaver/core/storage/filesystem-storage"
            }
          }
        },
        "redis": {
          "type": "object",
          "properties": {
            "url": {
              "type": "string",
              "default": "redis://localhost:6379/0"
            },
            "provider": {
              "type": "string",
              "default": "@appweaver/core/memory/redis"
            }
          }
        },
        "memory": {
          "type": "object",
          "properties": {
            "maxSizeBytes": {
              "type": ["integer", "null"]
            },
            "provider": {
              "type": "string",
              "default": "@appweaver/core/memory/in-memory"
            }
          }
        },
        "cache": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true
            },
            "cleanStart": {
              "type": "boolean",
              "default": false
            },
            "keyPrefix": {
              "type": "string",
              "default": "cache:"
            },
            "defaultTtl": {
              "type": "integer",
              "default": 5000
            },
            "evictionGracePeriod": {
              "type": "integer",
              "default": 10000
            },
            "evictionStrategy": {
              "type": "string",
              "enum": ["LRU", "LFU", "FIFO"],
              "default": "LRU"
            },
            "evictionDeferred": {
              "type": "boolean",
              "default": false
            },
            "invalidationStrategy": {
              "type": "string",
              "enum": ["expire-related", "expire-all", "none"],
              "default": "expire-related"
            },
            "invalidationDeferred": {
              "type": "boolean",
              "default": false
            },
            "provider": {
              "type": "string",
              "default": "@appweaver/core/cache/redis-cache"
            }
          }
        },
        "queue": {
          "type": "object",
          "properties": {
            "keepCompletedCount": {
              "type": "integer",
              "default": 0
            },
            "keepCompletedSeconds": {
              "type": ["integer", "null"]
            },
            "keepFailedCount": {
              "type": "integer",
              "default": 50
            },
            "keepFailedSeconds": {
              "type": ["integer", "null"]
            },
            "retryAttempts": {
              "type": "integer",
              "default": 3
            },
            "retryBackoff": {
              "type": "integer",
              "default": 3000
            },
            "retryBackoffType": {
              "type": "string",
              "enum": ["fixed", "exponential"],
              "default": "fixed"
            },
            "provider": {
              "type": "string",
              "default": "@appweaver/core/queue/bull-queue"
            }
          }
        },
        "scheduler": {
          "type": "object",
          "properties": {
            "autoStartJob": {
              "type": "boolean",
              "default": true
            },
            "provider": {
              "type": "string",
              "default": "@appweaver/core/scheduler/cron-scheduler"
            }
          }
        },
        "events": {
          "type": "object",
          "properties": {
            "maxListeners": {
              "type": "integer",
              "default": 10
            },
            "provider": {
              "type": "string",
              "default": "@appweaver/core/events/node-events"
            }
          }
        },
        "mail": {
          "type": "object",
          "properties": {
            "smtp": {
              "type": "object",
              "properties": {
                "host": {
                  "type": "string",
                  "default": "127.0.0.1"
                },
                "port": {
                  "type": "integer",
                  "default": 587
                },
                "secure": {
                  "type": "boolean",
                  "default": false
                },
                "user": {
                  "type": ["string", "null"]
                },
                "password": {
                  "type": ["string", "null"]
                }
              }
            },
            "senderName": {
              "type": ["string", "null"]
            },
            "senderAddress": {
              "type": ["string", "null"]
            },
            "provider": {
              "type": "string",
              "default": "@appweaver/core/mailer/smtp-mailer"
            }
          }
        },
        "system": {
          "type": "object",
          "properties": {
            "adminInitialEmail": {
              "type": "string",
              "default": "admin@appweaver.co"
            },
            "adminInitialPassword": {
              "type": ["string", "null"]
            }
          }
        }
      }
    }
  }
}
