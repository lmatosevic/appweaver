// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client"
}

// Generated by Appweaver. Please do not edit this part manually.
model User {
  id        Int     @id @default(autoincrement())
  firstName String
  lastName  String
  email     String  @unique
  phone     String?

  /// Related columns
  post Post?

  /// File columns
  avatar   File? @relation("UserAvatarFile", fields: [avatarId], references: [id])
  avatarId Int?

  /// Audit columns
  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())
  createdBy   Identity? @relation("UserCreatedByIdentity", fields: [createdById], references: [id])
  createdById Int?
}

enum PostStatus {
  Draft
  Published
  Archived
}

model Post {
  id           Int        @id @default(autoincrement())
  title        String
  slug         String     @unique
  content      String?
  counter      Int
  status       PostStatus @default(Draft)
  lastActivity DateTime?

  /// Related columns
  author   User @relation(fields: [authorId], references: [id])
  authorId Int  @unique

  /// File columns
  coverImage    File?  @relation("PostCoverImageFile", fields: [coverImageId], references: [id])
  coverImageId  Int?
  galleryImages File[] @relation("PostGalleryImagesFile")

  /// Audit columns
  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())
  createdBy   Identity? @relation("PostCreatedByIdentity", fields: [createdById], references: [id])
  createdById Int?
}

model Identity {
  id           Int       @id @default(autoincrement())
  username     String    @unique
  passwordHash String?
  enabled      Boolean   @default(true)
  logoutAt     DateTime?

  /// Related columns
  roles Role[] @relation("IdentityRoles")

  /// Audit columns
  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())
  createdBy   Identity? @relation("IdentityCreatedByIdentity", fields: [createdById], references: [id])
  createdById Int?

  /// Ownership relations connected with createdById column
  createdRoles       Role[]       @relation("RoleCreatedByIdentity")
  createdPermissions Permission[] @relation("PermissionCreatedByIdentity")
  createdIdentities  Identity[]   @relation("IdentityCreatedByIdentity")
  createdFiles       File[]       @relation("FileCreatedByIdentity")
  createdUsers       User[]       @relation("UserCreatedByIdentity")
  createdPosts       Post[]       @relation("PostCreatedByIdentity")
}

model Role {
  id   Int    @id @default(autoincrement())
  name String @unique

  /// Related columns
  identities  Identity[]   @relation("IdentityRoles")
  permissions Permission[] @relation("RolePermissions")

  /// Audit columns
  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())
  createdBy   Identity? @relation("RoleCreatedByIdentity", fields: [createdById], references: [id])
  createdById Int?
}

model Permission {
  id   Int    @id @default(autoincrement())
  name String @unique

  /// Related columns
  roles Role[] @relation("RolePermissions")

  /// Audit columns
  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())
  createdBy   Identity? @relation("PermissionCreatedByIdentity", fields: [createdById], references: [id])
  createdById Int?
}

model File {
  id            Int     @id @default(autoincrement())
  name          String  @unique
  originalName  String
  mimeType      String
  sizeBytes     Int
  title         String?
  description   String?
  resourceField String?
  resourceName  String?
  resourceId    Int?

  /// Audit columns
  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())
  createdBy   Identity? @relation("FileCreatedByIdentity", fields: [createdById], references: [id])
  createdById Int?

  /// Related models with files
  avatarUsers        User[] @relation("UserAvatarFile")
  coverImagePosts    Post[] @relation("PostCoverImageFile")
  galleryImagesPosts Post[] @relation("PostGalleryImagesFile")

  @@index([resourceField, resourceName, resourceId])
}
