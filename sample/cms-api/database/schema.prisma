// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client"
}

// Generated by Appweaver. Please do not edit this part manually.
model User {
  id        Int    @id @default(autoincrement())
  firstName String
  lastName  String
  email     String
  phone     String
  secret    String

  /// Related columns
  posts Post[] @relation("UserPostsPost")

  /// File columns
  avatar   File? @relation("UserAvatarFile", fields: [avatarId], references: [id])
  avatarId Int?  @unique

  /// Audit columns
  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())
  createdBy   Identity? @relation("UserCreatedByIdentity", fields: [createdById], references: [id])
  createdById Int?
}

model Post {
  id           Int         @id @default(autoincrement())
  title        String      @default("something...")
  slug         String      @unique
  content      String?
  counter      String
  status       PostStatus? @default(Draft)
  lastActivity DateTime?

  /// Related columns
  author   User? @relation("UserPostsPost", fields: [authorId], references: [id])
  authorId Int?

  /// File columns
  coverImage    File?  @relation("PostCoverImageFile", fields: [coverImageId], references: [id])
  coverImageId  Int?   @unique
  galleryImages File[] @relation("PostGalleryImagesFile")

  /// Audit columns
  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())
  createdBy   Identity? @relation("PostCreatedByIdentity", fields: [createdById], references: [id])
  createdById Int?
}

model Identity {
  id           Int       @id @default(autoincrement())
  username     String    @unique
  passwordHash String?
  enabled      Boolean   @default(true)
  logoutAt     DateTime?

  /// Related columns
  roles Role[] @relation("IdentityRolesRole")

  /// Ownership models referenced with createdById column
  createdUsers       User[]       @relation("UserCreatedByIdentity")
  createdPosts       Post[]       @relation("PostCreatedByIdentity")
  createdIdentities  Identity[]   @relation("IdentityCreatedByIdentity")
  createdRoles       Role[]       @relation("RoleCreatedByIdentity")
  createdPermissions Permission[] @relation("PermissionCreatedByIdentity")
  createdFiles       File[]       @relation("FileCreatedByIdentity")

  /// Audit columns
  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())
  createdBy   Identity? @relation("IdentityCreatedByIdentity", fields: [createdById], references: [id])
  createdById Int?
}

model Role {
  id   Int    @id @default(autoincrement())
  name String

  /// Related columns
  permissions Permission[] @relation("RolePermissionsPermission")
  identities  Identity[]   @relation("IdentityRolesRole")

  /// Audit columns
  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())
  createdBy   Identity? @relation("RoleCreatedByIdentity", fields: [createdById], references: [id])
  createdById Int?
}

model Permission {
  id   Int    @id @default(autoincrement())
  name String

  /// Related columns
  roles Role[] @relation("RolePermissionsPermission")

  /// Audit columns
  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())
  createdBy   Identity? @relation("PermissionCreatedByIdentity", fields: [createdById], references: [id])
  createdById Int?
}

model File {
  id            Int     @id @default(autoincrement())
  name          String  @unique
  originalName  String
  mimeType      String
  sizeBytes     Int
  title         String?
  description   String?
  resourceField String?
  resourceName  String?
  resourceId    Int?

  /// Related models with file columns
  avatarUsers        User[] @relation("UserAvatarFile")
  coverImagePosts    Post[] @relation("PostCoverImageFile")
  galleryImagesPosts Post[] @relation("PostGalleryImagesFile")

  /// Audit columns
  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())
  createdBy   Identity? @relation("FileCreatedByIdentity", fields: [createdById], references: [id])
  createdById Int?
}

enum PostStatus {
  Draft
  Published
  Archived
}
