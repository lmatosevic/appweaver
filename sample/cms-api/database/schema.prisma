datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client"
  output   = "./client"
}

model User {
  id           Int       @id @default(autoincrement())
  firstName    String
  lastName     String
  email        String    @unique
  phone        String
  secret       String?
  passwordHash String?
  enabled      Boolean   @default(true)
  logoutAt     DateTime?

  /// Related columns
  posts Post[] @relation("UserPostsPost")
  roles Role[] @relation("UserRolesRole")

  /// File columns
  avatar   File? @relation("UserAvatarFile", fields: [avatarId], references: [id])
  avatarId Int?  @unique

  /// Ownership models referenced with createdById column
  createdUsers       User[]       @relation("UserCreatedByUser")
  createdPosts       Post[]       @relation("PostCreatedByUser")
  createdRoles       Role[]       @relation("RoleCreatedByUser")
  createdPermissions Permission[] @relation("PermissionCreatedByUser")
  createdFiles       File[]       @relation("FileCreatedByUser")

  /// Audit columns
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
  createdBy   User?    @relation("UserCreatedByUser", fields: [createdById], references: [id])
  createdById Int?
}

model Post {
  id           Int         @id @default(autoincrement())
  title        String      @default("something...")
  slug         String      @unique
  content      String?
  counter      Int
  status       PostStatus? @default(Draft)
  tags         String      @default("Nature,Animals")
  jsonLd       Json?
  lastActivity DateTime?

  /// Related columns
  author   User? @relation("UserPostsPost", fields: [authorId], references: [id], onDelete: SetNull)
  authorId Int?

  /// File columns
  coverImage    File?  @relation("PostCoverImageFile", fields: [coverImageId], references: [id])
  coverImageId  Int?   @unique
  galleryImages File[] @relation("PostGalleryImagesFile")

  /// Audit columns
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
  createdBy   User?    @relation("PostCreatedByUser", fields: [createdById], references: [id])
  createdById Int?
}

model Role {
  id   Int    @id @default(autoincrement())
  name String @unique

  /// Related columns
  permissions Permission[] @relation("RolePermissionsPermission")
  users       User[]       @relation("UserRolesRole")

  /// Audit columns
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
  createdBy   User?    @relation("RoleCreatedByUser", fields: [createdById], references: [id])
  createdById Int?
}

model Permission {
  id   Int    @id @default(autoincrement())
  name String @unique

  /// Related columns
  roles Role[] @relation("RolePermissionsPermission")

  /// Audit columns
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
  createdBy   User?    @relation("PermissionCreatedByUser", fields: [createdById], references: [id])
  createdById Int?
}

model Seeder {
  id         String   @id @default(uuid())
  checksum   String
  seederName String   @unique
  startedAt  DateTime
  finishedAt DateTime
  logs       String?

  @@map("_seeders")
}

model File {
  id            Int     @id @default(autoincrement())
  name          String  @unique
  originalName  String
  mimeType      String
  sizeBytes     Int
  title         String?
  description   String?
  resourceField String?
  resourceName  String?
  resourceId    Int?

  /// Related models with file columns
  avatarUsers        User[] @relation("UserAvatarFile")
  coverImagePosts    Post[] @relation("PostCoverImageFile")
  galleryImagesPosts Post[] @relation("PostGalleryImagesFile")

  /// Audit columns
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
  createdBy   User?    @relation("FileCreatedByUser", fields: [createdById], references: [id])
  createdById Int?
}

enum PostStatus {
  Draft
