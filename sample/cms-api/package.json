{
  "name": "sample-cms-api",
  "version": "1.0.0",
  "description": "Appweaver sample - CMS API",
  "author": "Luka Matosevic",
  "private": true,
  "license": "UNLICENSED",
  "main": "./dist/src/main.js",
  "types": "./dist/src/main.d.ts",
  "scripts": {
    "build": "npm run weaver -- build",
    "start": "npm run weaver -- start",
    "dev": "npm run weaver -- start --watch",
    "generate": "npm run weaver -- generate",
    "migrate": "npm run weaver -- migrate",
    "seed": "npm run weaver -- seed",
    "test": "jest --forceExit --detectOpenHandles --coverage",
    "format": "prettier --write \"./**/*.ts\"",
    "lint": "eslint \"./**/*.ts\"",
    "weaver": "node ./../../node_modules/@appweaver/cli/weaver.js"
  },
  "dependencies": {
    "@appweaver/common": "^1.0.0",
    "@appweaver/core": "^1.0.0"
  },
  "devDependencies": {
    "@appweaver/cli": "^1.0.0"
  }
}
