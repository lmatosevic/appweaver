{
  "name": "sample-cms-api",
  "version": "1.0.0",
  "description": "Appweaver sample - CMS API",
  "author": "Luka Matosevic",
  "private": true,
  "license": "UNLICENSED",
  "main": "./dist/src/main.js",
  "types": "./dist/src/main.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node ./dist/src/main.js",
    "start:dev": "tsc-watch -p tsconfig.build.json --onSuccess \"node ./dist/src/main.js\"",
    "test": "jest --forceExit --detectOpenHandles --coverage",
    "format": "prettier --write \"./src/**/*.ts\" \"./test/**/*.ts\"",
    "lint": "eslint \"./{src,test}/**/*.ts\"",
    "lint:fix": "npm run lint -- --fix",
    "db:migrate": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:seed": "node ./dist/database/seeder/index.js",
    "weaver": "node ./../../node_modules/@appweaver/cli/dist/weaver.js"
  },
  "dependencies": {
    "@appweaver/common": "0.1.0",
    "@appweaver/core": "0.1.0"
  },
  "devDependencies": {
    "@appweaver/cli": "0.1.0"
  }
}
